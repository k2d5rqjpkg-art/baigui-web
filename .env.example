# DeepSeek API credentials.
# Copy this file to `.env` and fill in your real key.
# The LLM layer (src/core/llm/) reads these via process.env at runtime.
# If DEEPSEEK_API_KEY is unset, the layer transparently falls back to a
# static quest + dialogue table (see src/core/llm/fallback.ts).

DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat