{
  "name": "baigui-web",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "tsx server/server.ts",
    "server:bridge": "tsx server/bridge.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ server/ scripts/ --ext .ts,.js",
    "typecheck": "tsc --noEmit -p .",
    "ai:test": "vitest run src/core/sim/__tests__/fuzz-tick.test.ts src/core/sim/__tests__/replay.test.ts src/core/sim/__tests__/behavior-coverage.test.ts server/__tests__/smoke-e2e.test.ts server/__tests__/rl-agent.test.ts 2>&1 | tail -30",
    "ai:bench": "vitest run src/core/sim/__tests__/perf-bench.test.ts --reporter=verbose 2>&1 | tail -30",
    "ai:fuzz": "vitest run src/core/sim/__tests__/fuzz-tick.test.ts --reporter=verbose 2>&1 | tail -30",
    "ai:all": "npm run ai:test && npm run ai:bench && npm run ai:fuzz",
    "changelog": "node scripts/gen-changelog.mjs",
    "dump": "node scripts/state-dump.mjs",
    "bench:repl": "node scripts/bench-repl.mjs",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\" \"server/**/*.ts\" \"scripts/**/*.{ts,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\" \"server/**/*.ts\" \"scripts/**/*.{ts,mjs}\"",
    "bench:collect": "node scripts/bench-collect.mjs",
    "metrics": "node scripts/metrics-dashboard.mjs",
    "final:verify": "node scripts/final-verify.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/three": "^0.185.0",
    "pg": "^8.22.0",
    "three": "^0.185.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.5",
    "fast-check": "^3.23.2",
    "jsdom": "^24.1.3",
    "msw": "^2.15.0",
    "prettier": "^3.9.5",
    "tsx": "^4.20.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.9",
    "ws": "^8.18.3"
  }
}
