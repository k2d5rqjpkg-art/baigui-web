#!/usr/bin/env bash
# Day50: pre-commit hook — 跑关键测试 + format
# 安装: git config core.hooksPath .githooks
# 跳过: git commit --no-verify

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "${YELLOW}[pre-commit] 跑 typecheck...${NC}"
npm run typecheck --silent || { echo "${RED}✗ typecheck 失败${NC}"; exit 1; }

echo "${YELLOW}[pre-commit] 跑 AI 关键测试 (fuzz + replay)...${NC}"
npx vitest run \
  src/core/sim/__tests__/fuzz-tick.test.ts \
  src/core/sim/__tests__/replay.test.ts \
  --reporter=basic 2>&1 | tail -10 || { echo "${RED}✗ AI 测试失败${NC}"; exit 1; }

echo "${YELLOW}[pre-commit] 检查格式...${NC}"
npm run format:check --silent || {
  echo "${RED}✗ 格式错误 — 跑 npm run format 修正${NC}";
  exit 1;
}

echo "${GREEN}✓ pre-commit 全部通过${NC}"